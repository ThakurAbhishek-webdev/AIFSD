{
  "info": {
    "name": "Employee Analytics API",
    "description": "API collection for AI-Based Employee Performance Analytics System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "token",
      "value": "paste_your_jwt_token_here"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/signup" }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login" }
          }
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "Get All Employees",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/employees" }
          }
        },
        {
          "name": "Add Employee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Johnson\",\n  \"email\": \"alice@company.com\",\n  \"department\": \"Engineering\",\n  \"skills\": \"React, Node.js, MongoDB\",\n  \"performanceScore\": 88,\n  \"experience\": 5\n}"
            },
            "url": { "raw": "{{base_url}}/employees" }
          }
        },
        {
          "name": "Search by Department",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/employees/search?department=Engineering",
              "query": [{ "key": "department", "value": "Engineering" }]
            }
          }
        },
        {
          "name": "Update Employee",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"performanceScore\": 92,\n  \"experience\": 6\n}"
            },
            "url": { "raw": "{{base_url}}/employees/EMPLOYEE_ID_HERE" }
          }
        },
        {
          "name": "Delete Employee",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/employees/EMPLOYEE_ID_HERE" }
          }
        }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "Get AI Recommendation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employees\": [\n    {\n      \"name\": \"Alice Johnson\",\n      \"department\": \"Engineering\",\n      \"performanceScore\": 88,\n      \"experience\": 5,\n      \"skills\": [\"React\", \"Node.js\"]\n    },\n    {\n      \"name\": \"Bob Smith\",\n      \"department\": \"Marketing\",\n      \"performanceScore\": 55,\n      \"experience\": 2,\n      \"skills\": [\"SEO\"]\n    }\n  ]\n}"
            },
            "url": { "raw": "{{base_url}}/ai/recommend" }
          }
        }
      ]
    }
  ]
}
